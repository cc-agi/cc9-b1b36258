{
  "version": 1,
  "sdk_version": "0.22.2",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://vkghaxpqnrtyjsdlwugn.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "sentinel-os-mcp",
      "version": "0.3.0",
      "title": "Sentinel OS"
    },
    "tools": [
      {
        "name": "whoami",
        "title": "Who am I",
        "description": "Return the Sentinel OS user id and email of the caller. Use to verify the MCP connection is authenticated.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "get_version",
        "title": "Get version",
        "description": "Return Sentinel OS MCP versions: code, manifest, database schema, and minimum required local Helper version. Callers should compare their Helper build against `min_helper_version` and prompt the Owner to upgrade if older.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_mcp_connections",
        "title": "List MCP connections",
        "description": "List the caller's saved MCP server connections (id, name, base_url, transport, state, has_credentials, rotation_required, disabled_reason). base_url is redacted; original URLs and any auth tokens never leave the server.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "create_mcp_connection",
        "title": "Create MCP connection",
        "description": "Save a new MCP server connection for the signed-in user. Any secrets in the URL query (api key / token) are stripped and stored encrypted server-side; the returned `base_url` is safe to share. Browserbase URLs are automatically flagged `CREDENTIAL_ROTATION_REQUIRED` because that key has been in cleartext historically.",
        "annotations": {
          "readOnlyHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "url": {
              "type": "string",
              "format": "uri"
            },
            "transport": {
              "type": "string",
              "enum": [
                "http",
                "sse",
                "stdio"
              ],
              "default": "http"
            },
            "auth_type": {
              "type": "string",
              "enum": [
                "none",
                "oauth",
                "bearer",
                "custom"
              ],
              "default": "none"
            },
            "auth_metadata": {
              "type": "object",
              "additionalProperties": {}
            }
          },
          "required": [
            "name",
            "url"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "update_mcp_connection",
        "title": "Update MCP connection",
        "description": "Update fields of an existing MCP connection owned by the caller.",
        "annotations": {
          "readOnlyHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid"
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "url": {
              "type": "string",
              "format": "uri"
            },
            "transport": {
              "type": "string",
              "enum": [
                "http",
                "sse",
                "stdio"
              ]
            },
            "auth_type": {
              "type": "string",
              "enum": [
                "none",
                "oauth",
                "bearer",
                "custom"
              ]
            },
            "auth_metadata": {
              "type": "object",
              "additionalProperties": {}
            },
            "state": {
              "type": "string"
            }
          },
          "required": [
            "id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "delete_mcp_connection",
        "title": "Delete MCP connection",
        "description": "Delete one of the caller's saved MCP connections.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": true,
          "idempotentHint": true
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid"
            }
          },
          "required": [
            "id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_agent_runs",
        "title": "List agent runs",
        "description": "List the caller's recent Sentinel OS agent runs (goal, status, worker, heartbeat, timestamps). Newest first. Opportunistically sweeps stale runs so nothing stays stuck in queued.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 20,
              "description": "Max rows to return (1-50, default 20)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_agent_run",
        "title": "Get agent run",
        "description": "Fetch a single Sentinel OS agent run by id, including its ordered event log.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "run_id": {
              "type": "string",
              "format": "uuid",
              "description": "Agent run UUID."
            }
          },
          "required": [
            "run_id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "create_agent_run",
        "title": "Create agent run",
        "description": "Queue a new Sentinel OS agent run. If no local Sentinel Helper worker has heartbeat within the last 10s, the run is created as `blocked` with `error_code=WORKER_OFFLINE` — the Owner must start the Helper and explicitly call `retry_agent_run`.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "goal": {
              "type": "string",
              "minLength": 1,
              "maxLength": 4000,
              "description": "The task/goal in natural language."
            }
          },
          "required": [
            "goal"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "update_agent_run",
        "title": "Update agent run",
        "description": "Report a terminal outcome (succeeded or failed) on an agent run. Cancellation and retry have dedicated tools. Legal transitions are enforced at the database level.",
        "annotations": {
          "readOnlyHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid"
            },
            "status": {
              "type": "string",
              "enum": [
                "succeeded",
                "failed"
              ]
            },
            "final_output": {
              "type": "string"
            },
            "last_error": {
              "type": "string",
              "maxLength": 2000
            },
            "error_code": {
              "type": "string",
              "maxLength": 128
            }
          },
          "required": [
            "id",
            "status"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "retry_agent_run",
        "title": "Retry agent run",
        "description": "Owner-explicit retry: move a `blocked` or `failed` run back to `queued`. Terminal runs (succeeded/cancelled) cannot be retried. Browser side-effects are unknown, so retries never happen automatically — call this only when you understand the previous run's state.",
        "annotations": {
          "readOnlyHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid"
            }
          },
          "required": [
            "id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "cancel_agent_run",
        "title": "Cancel agent run",
        "description": "Request cancellation of an agent run. If the run is `queued` it is cancelled immediately. If it is `claimed`/`running`, this sets `cancel_requested_at` — the worker will finalize `cancelled` at the next heartbeat/step boundary. Idempotent.",
        "annotations": {
          "readOnlyHint": false,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid"
            }
          },
          "required": [
            "id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "delete_agent_run",
        "title": "Delete agent run",
        "description": "Delete an agent run (and its events via cascade if configured) owned by the caller.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": true,
          "idempotentHint": true
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid"
            }
          },
          "required": [
            "id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_worker_health",
        "title": "Get worker health",
        "description": "Report the caller's local Sentinel Helper worker status: last heartbeat, state, CDP reachability, current run, last error code. A worker with `last_seen_at` older than 10 seconds is considered offline — new runs will be created as `blocked / WORKER_OFFLINE`.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_agent_events",
        "title": "List agent events",
        "description": "List step events for a specific agent run owned by the caller.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "run_id": {
              "type": "string",
              "format": "uuid"
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 500,
              "default": 100
            }
          },
          "required": [
            "run_id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "append_agent_event",
        "title": "Append agent event",
        "description": "Append a step/log event to an agent run owned by the caller.",
        "annotations": {
          "readOnlyHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "run_id": {
              "type": "string",
              "format": "uuid"
            },
            "event_type": {
              "type": "string",
              "minLength": 1
            },
            "step_index": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            },
            "payload": {
              "type": "object",
              "additionalProperties": {},
              "default": {}
            }
          },
          "required": [
            "run_id",
            "event_type"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_imported_resources",
        "title": "List imported resources",
        "description": "List MCPs, plugins, and skills the caller has imported into Sentinel OS. Filter by kind.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "mcp",
                "plugin",
                "skill",
                "all"
              ],
              "default": "all",
              "description": "Filter by resource kind."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "upsert_imported_resource",
        "title": "Upsert imported resource",
        "description": "Create or update an imported resource (plugin / skill / MCP tool metadata) owned by the caller.",
        "annotations": {
          "readOnlyHint": false,
          "idempotentHint": true
        },
        "inputSchema": {
          "type": "object",
          "properties": {
