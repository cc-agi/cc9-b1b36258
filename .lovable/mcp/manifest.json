        "outputSchema": null
      },
      {
        "name": "cancel_agent_run",
        "title": "Cancel agent run",
        "description": "Request cancellation of an agent run. If the run is `queued` it is cancelled immediately. If it is `claimed`/`running`, this sets `cancel_requested_at` — the worker will finalize `cancelled` at the next heartbeat/step boundary. Idempotent.",
        "annotations": {
          "readOnlyHint": false,
          "idempotentHint": true,
          "openWorldHint": false
