            "url": {
              "type": "string",
              "format": "uri"
            },
            "transport": {
              "type": "string",
              "enum": [
                "http",
                "sse",
                "stdio"
              ],
              "default": "http"
            },
            "auth_type": {
              "type": "string",
              "enum": [
                "none",
                "oauth",
                "bearer",
                "custom"
