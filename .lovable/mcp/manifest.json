                "succeeded",
                "failed"
              ]
            },
            "final_output": {
              "type": "string"
            },
            "last_error": {
              "type": "string",
              "maxLength": 2000
            },
            "error_code": {
              "type": "string",
              "maxLength": 128
            }
          },
          "required": [
