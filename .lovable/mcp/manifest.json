        "inputSchema": {
          "type": "object",
          "properties": {
            "idempotency_key": {
              "type": "string",
              "minLength": 8,
              "maxLength": 128,
              "pattern": "^[A-Za-z0-9_.:-]+$"
            },
            "monitor": {
              "anyOf": [
