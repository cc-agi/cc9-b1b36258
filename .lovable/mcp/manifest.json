      {
        "name": "desktop_snapshot",
        "title": "Desktop screen snapshot",
        "description": "Capture a snapshot of one or all monitors. Screenshot bytes are stored locally on the Helper machine; only a local file path plus per-monitor bounds are returned. Requires an active Desktop Operator Session.",
        "annotations": {
          "readOnlyHint": true,
          "destructiveHint": false,
          "idempotentHint": true,
          "openWorldHint": false
